# ===============================================================
# Weather Sniper Bot v2.1 Pro — Observed Edge — Full Configuration
# ===============================================================

# TRADING MODE: 'paper' (dry-run) or 'live' (real money)
TRADING_MODE=paper
STARTING_BALANCE=3.0

# ===============================================================
# POLYMARKET WALLET (V2 — same as polymarket-bot-v2)
# ===============================================================
POLY_PRIVATE_KEY=0x_your_private_key_here
POLY_FUNDER_ADDRESS=0x_your_funder_or_proxy_address
POLY_PROXY_WALLET=0x_your_proxy_wallet_address
POLY_API_KEY=your_clob_api_key
POLY_API_SECRET=your_clob_api_secret
POLY_PASSPHRASE=your_clob_passphrase
POLY_SIGNATURE_TYPE=3
POLY_CHAIN_ID=137

# ===============================================================
# BUILDER RELAYER (for V2 order attribution)
# ===============================================================
POLY_BUILDER_API_KEY=
POLY_BUILDER_SECRET=
POLY_BUILDER_PASSPHRASE=
POLY_BUILDER_CODE=

# ===============================================================
# WEATHER APIs
# ===============================================================
OPENWEATHER_API_KEY=your_openweather_api_key
# Open-Meteo: FREE, no key needed (used by the observed-weather engine)
# weather.gov: FREE, no key needed

# ===============================================================
# ML DECISION ENGINE (GPT-5.5 via Freemodel)
# ===============================================================
ML_API_URL=https://vip-sg.freemodel.dev/v1
ML_API_KEY=your_freemodel_api_key
ML_MODEL=gpt-5.5
ML_ENABLED=1

# ===============================================================
# RESOLUTION-STATION VERIFICATION (OpenAI Responses API)
# Make sure we forecast the EXACT airport each market settles on. The rules
# are pulled from the Gamma event metadata and matched to our hardcoded
# station DETERMINISTICALLY (0 tokens). The cheap LLM below is called ONLY
# when a station is ambiguous or different, then adjusts the coordinate.
# Endpoint:  POST {ML_RESPONSES_URL}/responses   (api: "openai-responses")
# Re-uses ML_API_KEY above.
# ===============================================================
ML_RESPONSES_URL=https://api.freemodel.dev/v1
ML_VERIFY_MODEL=gpt-5.4-mini       # fast, NON-reasoning, low-token
RESOLUTION_VERIFY_ENABLED=1        # 0 = deterministic-only (never call the LLM)
RESOLUTION_VERIFY_MIN_CONF=0.6     # min LLM confidence to trust adjusted coords
RESOLUTION_SKIP_ON_UNKNOWN=0       # 1 = skip a market when its station can't be verified

# ===============================================================
# FEATURE TOGGLES (1=on, 0=off — change without code)
# OVERHAUL: LateObserved is the PRIMARY strategy; the forecast-only
# PeakBasket/Confident strategies are demoted to opt-in.
# ===============================================================
SNIPER_ENABLED=0
SPREAD_STRATEGY_ENABLED=0
SELECTIVE_SNIPER_ENABLED=0
QUICK_FLIP_ENABLED=0
CORRELATION_ARB_ENABLED=0
CONFIDENT_ENABLED=0              # demoted (was 1) — forecast-only fallback
STABILITY_ENABLED=1              # enabled (was 0) — grade scales size across strategies
PEAK_BASKET_ENABLED=0            # demoted (was 1) — superseded by LateObserved
LOCKIN_ENABLED=1
COPY_TRADING_ENABLED=0
ADAPTIVE_EXIT_ENABLED=1
AUTO_REDEEM_ENABLED=1
DRAWDOWN_GATE_ENABLED=1
TELEGRAM_ENABLED=1

# ===============================================================
# LATE OBSERVED-TEMPERATURE STRATEGY (PRIMARY)
# Once the local day's peak/trough is locked, the observed max/min is a
# hard floor/ceiling on settlement while the book still prices stale
# forecast uncertainty. YES the locked bucket; NO the buckets observed
# data has ruled out. All gating is fee-aware (taker fee = 5% x p x (1-p)).
# ===============================================================
LATE_OBSERVED_ENABLED=1          # master switch for the primary strategy
LATE_OBSERVED_NO_SIDE=1          # also buy NO on buckets the day has ruled out
LATE_OBSERVED_MIN_LOCK=0.70      # min lock-confidence (0-1) before trading
LATE_OBSERVED_MIN_EDGE=0.10      # post-fee probability cushion required
LATE_OBSERVED_MAX_YES_PRICE=0.95 # don't pay through the roof for a YES leg
LATE_OBSERVED_NO_MIN_PRICE=0.04  # only NO a dead bucket if book still prices it richly
LATE_OBSERVED_NO_MAX_PRICE=0.97  # NO token price ceiling (avoid ~$1 no-edge fills)
LATE_OBSERVED_BASE_FRACTION=0.06 # base stake as a fraction of balance
LATE_OBSERVED_MAX_FRACTION=0.25  # cap per-leg stake fraction
LATE_OBSERVED_MAX_LEGS=4         # max legs per market per scan

# Fee-aware EV gating: 1 = assume the conservative TAKER fee in EV/break-even
# checks. Keep on unless every fill is guaranteed to be a resting maker order.
ASSUME_TAKER_FILLS=1

# ===============================================================
# STABILITY STRATEGY — trade only predictable city-days, adjacent buckets
# ===============================================================
STABILITY_MIN_SCORE=0.62          # predictable threshold (0-1); lower = more trades
STABILITY_NEIGHBOR_SPAN=1         # buy center +/-N buckets (1 -> 3 buckets)
STABILITY_MAX_LEG_PRICE=0.60      # skip legs priced above this
STABILITY_MIN_EDGE=0.08           # require basket P(win) - cost >= this
STABILITY_MAX_FRACTION=0.25       # max % of balance per basket (scaled by score)
STABILITY_EARLY_EXIT_PRICE=0.85   # unstable days: take profit here instead of holding
STABILITY_EXIT_HOURS_BEFORE=1.0   # unstable days: exit this many hours before resolution

# ===============================================================
# PEAK BASKET (DEMOTED — forecast-only directional-peak; off by default)
# ===============================================================
PEAK_MIN_STABILITY=0.45            # minimum grade to trade (lower = more trades)
PEAK_MAX_PEAK_PRICE=0.85           # skip if peak is already priced above this
PEAK_MAX_NEIGHBOR_PRICE=0.60       # skip neighbor if > this (too expensive for insurance)
PEAK_MAX_BASKET_COST=0.95          # sum(leg market prices) must be < this (>=5% profit)
PEAK_MIN_EDGE=0.03                 # P(win) - basket_cost minimum
PEAK_BASE_FRACTION=0.05            # base % of balance per basket
PEAK_MAX_FRACTION=0.25             # max % of balance (when everything aligns)
PEAK_MIN_MODELS=2                  # minimum ensemble models required to trade
MIN_ENTRY_PRICE=0.05               # HARD floor: never buy a leg cheaper than 5c (unsellable)
HIGHEST_TEMP_ONLY=0                # 0 = trade highs AND lows (was 1); LateObserved handles both

# ===============================================================
# BASKET QUALITY (used by demoted forecast strategies)
# ===============================================================
BASKET_MAX_COST=0.85
BASKET_TIGHT_GRADE=0.80
BASKET_TIGHT_CONFIDENCE=0.70

# ===============================================================
# SNIPER GATE (used by demoted forecast strategies)
# ===============================================================
SNIPER_MIN_GRADE=0.70
SNIPER_MIN_CONFIDENCE=0.60
SNIPER_MIN_PROBABILITY=0.12

# Master trading switch — toggled live via Telegram /start /stop
TRADING_ENABLED=1

# ===============================================================
# OUTCOME-DECIDED GATE — never trade a market whose measurement window has
# already closed in the CITY'S LOCAL time. NOTE: LateObserved deliberately
# trades the almost-decided window (after the lock hour, before UMA resolves).
# ===============================================================
SKIP_DECIDED_MARKETS=1            # 1 = skip markets whose local measurement window has passed
HIGH_TEMP_LOCK_HOUR=18            # local hour after which the day's HIGH is treated as set

# ===============================================================
# STABILITY GRADE — stability is a GRADE, not a strategy. It scales size and
# sets the exit for EVERY strategy. Higher grade = bigger size + hold.
# ===============================================================
GRADE_SIZING_ENABLED=1
GRADE_NEUTRAL=0.60
GRADE_MIN_TO_TRADE=0.35
GRADE_SIZE_MIN_MULT=0.30
GRADE_SIZE_MAX_MULT=1.25

# ===============================================================
# LIQUIDITY AWARENESS — weather books are thin & asymmetric. The bot READS
# the book and ADAPTS: maker entry at best_bid, trims size on thin/wide books,
# holds to resolution when too thin to exit. STRICT by default now.
# ===============================================================
LIQUIDITY_GUARD_ENABLED=1        # read & adapt to the order book
LIQUIDITY_STRICT_BLOCK=1         # 1 = hard-skip trades that fail the guard (was 0)
LIQUIDITY_THIN_SIZE_MULT=0.5     # trim size to this fraction on thin/wide books
LIQUIDITY_BOOK_CACHE_SECONDS=30  # reuse a fetched order book for this many seconds

# ===============================================================
# CITY FILTER (empty = ALL cities)
# ===============================================================
ENABLED_CITIES=
# Example: ENABLED_CITIES=tokyo,seoul,ankara,london,beijing

# ===============================================================
# TRADING PARAMETERS
# ===============================================================
SNIPER_MAX_ENTRY_PRICE=0.15
MIN_EDGE_TO_ENTER=0.10
KELLY_FRACTION=0.15
MAX_BET_PCT=0.20
MAX_POSITIONS=10
MAX_SINGLE_MARKET_PCT=0.30

# ===============================================================
# RISK (weather is binary — SL almost never triggers)
# ===============================================================
STOP_LOSS_PCT=-95
TRAILING_STOP_PCT=30
EARLY_PROFIT_THRESHOLD=0.60
CONFIDENT_NEVER_SELL=1

# ===============================================================
# DRAWDOWN GATE
# ===============================================================
MAX_DAILY_DRAWDOWN_PCT=30
MAX_WEEKLY_DRAWDOWN_PCT=50
DRAWDOWN_COOLDOWN_MINUTES=60

# ===============================================================
# MULTI-OUTCOME SPREAD
# ===============================================================
SPREAD_NEIGHBOR_DECAY=0.4
SPREAD_MAX_COST=1.50

# ===============================================================
# LOCK-IN STRATEGY
# ===============================================================
LOCKIN_MIN_PRICE=0.90
LOCKIN_MIN_CONFIDENCE=0.85
LOCKIN_MAX_BET_PCT=0.40

# ===============================================================
# COPY TRADING (mirror Wallet1)
# ===============================================================
COPY_WALLET=0x594edb9112f526fa6a80b8f858a6379c8a2c1c11
COPY_SCALE_FACTOR=0.01
COPY_POLL_INTERVAL=30

# ===============================================================
# SCAN SETTINGS
# ===============================================================
SCAN_INTERVAL_SECONDS=60
SCAN_DAYS_AHEAD=3

# ===============================================================
# TELEGRAM (optional — for alerts)
# ===============================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ===============================================================
# POLYGON RPC (for on-chain balance check)
# ===============================================================
POLYGON_RPC_URL=
CLOB_RELAY_URL=

# ===============================================================
# LOGGING
# ===============================================================
LOG_FILE=weather_bot.log
LOG_LEVEL=INFO
