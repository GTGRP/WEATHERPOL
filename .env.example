# ═══════════════════════════════════════════════════════════════
# Weather Sniper Bot v2.0 Pro — Full Configuration
# ═══════════════════════════════════════════════════════════════

# TRADING MODE: 'paper' (dry-run) or 'live' (real money)
TRADING_MODE=paper
STARTING_BALANCE=3.0

# ═══════════════════════════════════════════════════════════════
# POLYMARKET WALLET (V2 — same as polymarket-bot-v2)
# ═══════════════════════════════════════════════════════════════
POLY_PRIVATE_KEY=0x_your_private_key_here
POLY_FUNDER_ADDRESS=0x_your_funder_or_proxy_address
POLY_PROXY_WALLET=0x_your_proxy_wallet_address
POLY_API_KEY=your_clob_api_key
POLY_API_SECRET=your_clob_api_secret
POLY_PASSPHRASE=your_clob_passphrase
POLY_SIGNATURE_TYPE=3
POLY_CHAIN_ID=137

# ═══════════════════════════════════════════════════════════════
# BUILDER RELAYER (for V2 order attribution)
# Get from: polymarket.com → Settings → Developer → Builder Program
# ═══════════════════════════════════════════════════════════════
POLY_BUILDER_API_KEY=
POLY_BUILDER_SECRET=
POLY_BUILDER_PASSPHRASE=
POLY_BUILDER_CODE=

# ═══════════════════════════════════════════════════════════════
# WEATHER APIs
# ═══════════════════════════════════════════════════════════════
OPENWEATHER_API_KEY=your_openweather_api_key
# Open-Meteo: FREE, no key needed
# weather.gov: FREE, no key needed

# ═══════════════════════════════════════════════════════════════
# ML DECISION ENGINE (GPT-5.5 via Freemodel)
# ═══════════════════════════════════════════════════════════════
ML_API_URL=https://vip-sg.freemodel.dev/v1
ML_API_KEY=your_freemodel_api_key
ML_MODEL=gpt-5.5
ML_ENABLED=1

# ═══════════════════════════════════════════════════════════════
# FEATURE TOGGLES (1=on, 0=off — change without code)
# ═══════════════════════════════════════════════════════════════
SNIPER_ENABLED=1
SPREAD_STRATEGY_ENABLED=1
SELECTIVE_SNIPER_ENABLED=1
QUICK_FLIP_ENABLED=1
CORRELATION_ARB_ENABLED=1
CONFIDENT_ENABLED=1
STABILITY_ENABLED=1
LOCKIN_ENABLED=1
COPY_TRADING_ENABLED=0
ADAPTIVE_EXIT_ENABLED=1
AUTO_REDEEM_ENABLED=1
DRAWDOWN_GATE_ENABLED=1
TELEGRAM_ENABLED=1

# ═══════════════════════════════════════════════════════════════
# STABILITY STRATEGY — trade only predictable city-days, adjacent buckets
# Backtest (real archived forecasts, 90d): actual high within ±1°C of forecast
# ~86% of days on stable cities (Singapore 100%, London 87%, Seoul 71%).
# ═══════════════════════════════════════════════════════════════
STABILITY_MIN_SCORE=0.62          # predictable threshold (0-1); lower = more trades
STABILITY_NEIGHBOR_SPAN=1         # buy center ±N buckets (1 → 3 buckets: 23+24+25)
STABILITY_MAX_LEG_PRICE=0.60      # skip legs priced above this
STABILITY_MIN_EDGE=0.08           # require basket P(win) - cost >= this
STABILITY_MAX_FRACTION=0.25       # max % of balance per basket (scaled by score)
STABILITY_EARLY_EXIT_PRICE=0.85   # unstable days: take profit here instead of holding
STABILITY_EXIT_HOURS_BEFORE=1.0   # unstable days: exit this many hours before resolution

# ═══════════════════════════════════════════════════════════════
# BASKET QUALITY — predict the max temp, then buy an adjacent basket whose
# COMBINED cost < BASKET_MAX_COST so ANY single winning leg nets profit.
# Width is conviction-driven: high grade+confidence → tight (center + lean
# neighbor, e.g. 24+25); lower → wider (23+24+25).
# ═══════════════════════════════════════════════════════════════
BASKET_MAX_COST=0.85              # sum(leg prices) must be below this (0.85 → >=~18% profit on any win)
BASKET_TIGHT_GRADE=0.80           # grade >= this (with high conf) → tight 2-leg basket
BASKET_TIGHT_CONFIDENCE=0.70      # center-bucket confidence >= this for the tight basket

# ═══════════════════════════════════════════════════════════════
# SNIPER GATE — the lone cheap-tail sniper only fires on high-conviction
# stable city-days (else it buys junk cheap positions). Require both.
# ═══════════════════════════════════════════════════════════════
SNIPER_MIN_GRADE=0.70             # stability grade required for a lone sniper buy
SNIPER_MIN_CONFIDENCE=0.60        # model confidence required for a lone sniper buy
SNIPER_MIN_PROBABILITY=0.12       # skip buckets our model gives <12% chance (no cheap lottery buys)

# Master trading switch — toggled live via Telegram /start /stop
TRADING_ENABLED=1

# ═══════════════════════════════════════════════════════════════
# OUTCOME-DECIDED GATE — never trade a market whose measurement window has
# already closed in the CITY'S LOCAL time. The day's high/low is a recorded
# fact by then; the market only stays open because UMA hasn't resolved yet.
# ═══════════════════════════════════════════════════════════════
SKIP_DECIDED_MARKETS=1            # 1 = skip markets whose local measurement window has passed
HIGH_TEMP_LOCK_HOUR=18            # local hour after which the day's HIGH is treated as set (afternoon peak done)

# ═══════════════════════════════════════════════════════════════
# STABILITY GRADE — stability is a GRADE, not a strategy. It scales
# size and sets the exit for EVERY strategy (sniper/spread/confident/
# adjacent-basket). Higher grade = more stable weather = bigger size + hold.
# ═══════════════════════════════════════════════════════════════
GRADE_SIZING_ENABLED=1            # apply the stability grade as a size multiplier across all strategies
GRADE_NEUTRAL=0.60               # default grade when stability data is missing (keeps non-stability strats trading)
GRADE_MIN_TO_TRADE=0.35          # hard skip any trade when grade is below this
GRADE_SIZE_MIN_MULT=0.30         # size multiplier at grade 0 (least stable)
GRADE_SIZE_MAX_MULT=1.25         # size multiplier at grade 1 (most stable)

# ═══════════════════════════════════════════════════════════════
# LIQUIDITY AWARENESS — weather books are thin & asymmetric (buy ~3¢, sell ~1.5¢).
# The bot READS the book and ADAPTS: maker entry at best_bid (0% fee), trims
# size on thin/wide books, and prefers holding to full resolution when it's
# too thin to exit. It does NOT block trading (advisory) unless STRICT_BLOCK=1.
# ═══════════════════════════════════════════════════════════════
LIQUIDITY_GUARD_ENABLED=1        # read & adapt to the order book
LIQUIDITY_STRICT_BLOCK=0         # 0 = advisory (never skip); 1 = hard-skip trades that fail the guard
LIQUIDITY_THIN_SIZE_MULT=0.5     # trim size to this fraction on thin/wide books
LIQUIDITY_BOOK_CACHE_SECONDS=30  # reuse a fetched order book for this many seconds

# ═══════════════════════════════════════════════════════════════
# CITY FILTER (empty = ALL cities)
# ═══════════════════════════════════════════════════════════════
ENABLED_CITIES=
# Example: ENABLED_CITIES=tokyo,seoul,ankara,london,beijing

# ═══════════════════════════════════════════════════════════════
# TRADING PARAMETERS
# ═══════════════════════════════════════════════════════════════
SNIPER_MAX_ENTRY_PRICE=0.15
MIN_EDGE_TO_ENTER=0.10
KELLY_FRACTION=0.15
MAX_BET_PCT=0.20
MAX_POSITIONS=10
MAX_SINGLE_MARKET_PCT=0.30

# ═══════════════════════════════════════════════════════════════
# RISK (weather is binary — SL almost never triggers)
# ═══════════════════════════════════════════════════════════════
STOP_LOSS_PCT=-95
TRAILING_STOP_PCT=30
EARLY_PROFIT_THRESHOLD=0.60
CONFIDENT_NEVER_SELL=1

# ═══════════════════════════════════════════════════════════════
# DRAWDOWN GATE
# ═══════════════════════════════════════════════════════════════
MAX_DAILY_DRAWDOWN_PCT=30
MAX_WEEKLY_DRAWDOWN_PCT=50
DRAWDOWN_COOLDOWN_MINUTES=60

# ═══════════════════════════════════════════════════════════════
# MULTI-OUTCOME SPREAD
# ═══════════════════════════════════════════════════════════════
SPREAD_NEIGHBOR_DECAY=0.4
SPREAD_MAX_COST=1.50

# ═══════════════════════════════════════════════════════════════
# LOCK-IN STRATEGY
# ═══════════════════════════════════════════════════════════════
LOCKIN_MIN_PRICE=0.90
LOCKIN_MIN_CONFIDENCE=0.85
LOCKIN_MAX_BET_PCT=0.40

# ═══════════════════════════════════════════════════════════════
# COPY TRADING (mirror Wallet1)
# ═══════════════════════════════════════════════════════════════
COPY_WALLET=0x594edb9112f526fa6a80b8f858a6379c8a2c1c11
COPY_SCALE_FACTOR=0.01
COPY_POLL_INTERVAL=30

# ═══════════════════════════════════════════════════════════════
# SCAN SETTINGS
# ═══════════════════════════════════════════════════════════════
SCAN_INTERVAL_SECONDS=60
SCAN_DAYS_AHEAD=3

# ═══════════════════════════════════════════════════════════════
# TELEGRAM (optional — for alerts)
# ═══════════════════════════════════════════════════════════════
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ═══════════════════════════════════════════════════════════════
# POLYGON RPC (for on-chain balance check)
# ═══════════════════════════════════════════════════════════════
POLYGON_RPC_URL=
CLOB_RELAY_URL=

# ═══════════════════════════════════════════════════════════════
# LOGGING
# ═══════════════════════════════════════════════════════════════
LOG_FILE=weather_bot.log
LOG_LEVEL=INFO
